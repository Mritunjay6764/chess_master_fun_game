    "@types/jest": "^29.5.13",
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "typescript": "~5.9.2"
