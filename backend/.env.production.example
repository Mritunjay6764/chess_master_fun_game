# Production backend environment — copy to .env on your production server
# Replace all placeholder values before deploying

NODE_ENV=production
PORT=3001

# PostgreSQL connection string (replace with your actual DB credentials)
DATABASE_URL="postgresql://chessmaster_user:CHANGE_ME@localhost:5432/chessmaster_prod?schema=public"

# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# CORS: your production frontend domain or Expo app
CORS_ORIGIN=https://chessmaster.app

# Redis (optional — for scaling socket.io across multiple instances)
# REDIS_URL=redis://localhost:6379
